<div class="content-page">
    <div class="content-page__header">
        <h1 class="content-page__title">Auditoria</h1>
    </div>

    <main class="auditoria-kanban" aria-label="Kanban de auditoria">
        <?
        $statusAuditoria = !empty($this->statusAuditoria) ? $this->statusAuditoria : array();
        $inscricoesPorStatus = array();
        if (!empty($this->inscricoesAuditoria)) {
            foreach ($this->inscricoesAuditoria as $inscricao) {
                $idStatus = (int) $inscricao['id_status_auditoria'];
                if (!isset($inscricoesPorStatus[$idStatus])) {
                    $inscricoesPorStatus[$idStatus] = array();
                }
                $inscricoesPorStatus[$idStatus][] = $inscricao;
            }
        }
        if (count($statusAuditoria) > 0): foreach ($statusAuditoria as $status):
            $cor = !empty($status['cor']) && preg_match('/^#[0-9A-Fa-f]{6}$/', $status['cor']) ? $status['cor'] : '#475569';
            $idStatus = (int) $status['id_status_auditoria'];
            $inscricoes = isset($inscricoesPorStatus[$idStatus]) ? $inscricoesPorStatus[$idStatus] : array();
        ?>
                <section class="auditoria-kanban__lane" data-status-auditoria="<?= $idStatus ?>" style="--auditoria-cor: <?= $this->escape($cor) ?>;">
                    <header class="auditoria-kanban__lane-header">
                        <div class="auditoria-kanban__lane-heading">
                            <span class="auditoria-kanban__lane-color" aria-hidden="true"></span>
                            <h2 class="auditoria-kanban__lane-title"><?= $this->escape($status['nome']) ?></h2>
                        </div>
                        <span class="auditoria-kanban__lane-count"><?= count($inscricoes) ?></span>
                    </header>
                    <div class="auditoria-kanban__lane-body">
                        <? if (count($inscricoes) > 0): foreach ($inscricoes as $inscricao): ?>
                            <article class="auditoria-kanban__card" data-id-inscricao="<?= (int) $inscricao['id_inscricao'] ?>" role="button" tabindex="0">
                                <h3 class="auditoria-kanban__card-title"><?= $this->escape($inscricao['nome_organizacao']) ?></h3>
                                <div class="auditoria-kanban__card-row">
                                    <span class="auditoria-kanban__card-label">Responsavel</span>
                                    <span class="auditoria-kanban__card-value"><?= $this->escape($inscricao['nome']) ?></span>
                                </div>
                            </article>
                        <? endforeach; else: ?>
                            <div class="auditoria-kanban__empty">Nenhum item nesta raia.</div>
                        <? endif; ?>
                    </div>
                </section>
        <? endforeach;
        else: ?>
            <div class="alert alert-info mb-0">
                Nenhuma raia de auditoria configurada para o seu perfil.
            </div>
        <? endif; ?>
    </main>
</div>

