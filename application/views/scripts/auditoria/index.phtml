<script type="text/javascript">
    $(document).ready(function() {
        $('.auditoria-kanban__card').on('click keydown', function(e) {
            if (e.type === 'keydown' && e.key !== 'Enter' && e.key !== ' ') {
                return;
            }

            e.preventDefault();
            var idInscricao = $(this).data('id-inscricao');
            if (idInscricao) {
                <? if ((int) ($this->permissao ?? 0) === 2) : ?>
                    carregarTela('../../projeto?id_inscricao=' + idInscricao);
                <? else : ?>
                    carregarTela('../../inscricao/detalhe?id_inscricao=' + idInscricao);
                <? endif; ?>
            }
        });

    });
</script>
