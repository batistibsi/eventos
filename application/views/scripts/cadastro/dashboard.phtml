</div>

<script type="text/javascript">
	$(document).ready(function() {
		function syncDashboardCarrosselImagens() {
			var urls = [];
			$('.dashboard-admin-gallery__item').each(function() {
				var url = ($(this).data('image-url') || '').toString().trim();
				if (url.length) {
					urls.push(url);
				}
			});
			$('#dashboard_carrossel_imagens').val(urls.join("\n"));
		}

		var dashboardDropzone = new Dropzone('#dashboard-dropzone', {
			url: '#',
			autoProcessQueue: false,
			uploadMultiple: true,
			parallelUploads: 10,
			maxFilesize: 10,
			addRemoveLinks: true,
			paramName: 'dashboard_carrossel_upload',
			clickable: true,
			acceptedFiles: '.png,.jpg,.jpeg,.webp',
			dictDefaultMessage: 'Arraste imagens aqui ou clique para selecionar',
			dictRemoveFile: 'Remover',
			dictFileTooBig: 'Imagem muito grande. Tamanho maximo: 10 MB.',
			dictInvalidFileType: 'Tipo de imagem nao permitido.'
		});

		$(document).on('click', '.dashboard-admin-gallery__remove', function() {
			$(this).closest('.dashboard-admin-gallery__item').remove();
			syncDashboardCarrosselImagens();
		});

		$('#form-dashboard-config').submit(function(e) {
			e.preventDefault();

			if (!this.checkValidity()) {
				this.reportValidity();
				return false;
			}

			$('.salvar-dashboard').hide();
			var formData = new FormData(this);
			dashboardDropzone.getAcceptedFiles().forEach(function(file) {
				formData.append('dashboard_carrossel_upload[]', file, file.name);
			});

			$.ajax({
				type: "POST",
				url: "../../cadastro/salvardashboard",
				data: formData,
				processData: false,
				contentType: false,
				success: function(data) {
					if (data.trim().length > 0) {
						$('.salvar-dashboard').show();
						swal({
							title: "Atencao!",
							text: data,
							type: "error"
						});
						return;
					}

					swal({
						title: "Sucesso!",
						text: "Configuracao do dashboard salva com sucesso.",
						type: "success"
					}, function() {
						carregarTela('../../cadastro/dashboard');
					});
				},
				error: function() {
					$('.salvar-dashboard').show();
					swal({
						title: "Atencao!",
						text: "Nao foi possivel salvar a configuracao do dashboard.",
						type: "error"
					});
				}
			});
		});
	});
</script>
