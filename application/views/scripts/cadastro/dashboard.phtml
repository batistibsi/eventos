			<div class="section-header">
				<div>
					<h2 class="section-title">Conteudo principal</h2>
					<p class="section-subtitle">As datas da trilha vem automaticamente do evento vinculado a inscricao do usuario.</p>
				</div>
			</div>
			<div class="row">
				<div class="form-group col-md-6">
					<span><label for="dashboard_titulo">Titulo principal: </label></span>
					<input class="form-control" name="dashboard_titulo" id="dashboard_titulo" maxlength="150" value="<?= $this->escape($registro['dashboard_titulo'] ?? '') ?>" required>
				</div>
				<div class="form-group col-md-6">
					<span><label for="dashboard_aviso_texto">Aviso em destaque: </label></span>
					<textarea class="form-control" name="dashboard_aviso_texto" id="dashboard_aviso_texto" rows="3"><?= $this->escape($registro['dashboard_aviso_texto'] ?? '') ?></textarea>
				</div>
			</div>
		</div>

		<div class="section-card">
			<div class="section-header">
				<div>
					<h2 class="section-title">Carrossel</h2>
					<p class="section-subtitle">Envie imagens para o carrossel. Dimensao sugerida: 1600 x 900 px. Minimo recomendado: 1200 x 675 px.</p>
				</div>
			</div>
			<div class="row">
				<div class="form-group col-md-12">
					<span><label for="dashboard-dropzone">Upload de imagens: </label></span>
					<div id="dashboard-dropzone" class="dropzone">
						<div class="dz-message">
							Arraste imagens aqui ou clique para selecionar.<br>
							<small>Formatos aceitos: PNG, JPG, JPEG e WEBP.</small>
						</div>
					</div>
					<input type="hidden" name="dashboard_carrossel_imagens" id="dashboard_carrossel_imagens" value="<?= $this->escape($registro['dashboard_carrossel_imagens'] ?? '') ?>">
					<div class="upload-subtitle mt-2">Formatos aceitos: PNG, JPG, JPEG e WEBP. Tamanho maximo: 10 MB por imagem.</div>
				</div>
				<? if (count($imagensCarrossel)) : ?>
					<div class="form-group col-md-12">
						<span class="field-label">Imagens atuais</span>
						<div class="dashboard-admin-gallery">
							<? foreach ($imagensCarrossel as $imagem) : ?>
								<div class="dashboard-admin-gallery__item" data-image-url="<?= $this->escape($imagem) ?>">
									<button type="button" class="dashboard-admin-gallery__remove" title="Excluir imagem"><i class="fa fa-trash" aria-hidden="true"></i></button>
