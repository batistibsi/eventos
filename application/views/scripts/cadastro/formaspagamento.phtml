<script type="text/javascript">
	$(document).ready(function() {
		function salvarFormaPagamento(payload, botao) {
			botao.prop('disabled', true);

			$.ajax({
				type: "POST",
				url: "../../cadastro/salvarformapagamento",
				data: payload,
				success: function(data) {
					if (data.trim().length > 0) {
						swal({
							title: "Atencao!",
							text: data,
							type: "error"
						});
						botao.prop('disabled', false);
						return;
					}

					swal({
						title: "Sucesso!",
						text: "Forma de pagamento salva com sucesso.",
						type: "success"
					}, function() {
						carregarTela('../../cadastro/formaspagamento');
					});
				},
				error: function() {
					botao.prop('disabled', false);
					swal({
						title: "Atencao!",
						text: "Nao foi possivel salvar a forma de pagamento.",
						type: "error"
					});
				}
			});
		}

		$('.form-forma-pagamento-nova').submit(function(e) {
			e.preventDefault();

			if (!this.checkValidity()) {
				this.reportValidity();
				return false;
			}

			var form = $(this);
			salvarFormaPagamento(form.serialize(), form.find('.salvar-forma-pagamento'));
		});

		$('.salvar-forma-pagamento-linha').click(function() {
			var linha = $(this).closest('.linha-forma-pagamento');
			var descricao = linha.find('input[name="descricao"]');

			if (!descricao[0].checkValidity()) {
				descricao[0].reportValidity();
				return false;
			}

			salvarFormaPagamento(linha.find(':input').serialize(), $(this));
		});
	});
</script>
