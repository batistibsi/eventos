<script type="text/javascript">
	$(document).ready(function() {
		$('#form-material-config').submit(function(e) {
			e.preventDefault();

			if (!this.checkValidity()) {
				this.reportValidity();
				return false;
			}

			var possuiErro = false;
			$('.material-video-upload, .material-arquivo-upload').each(function() {
				var inputArquivo = $(this);
				var possuiArquivoNovo = (inputArquivo.val() || '').trim().length > 0;
				if (!possuiArquivoNovo) {
					return;
				}

				var seletorTitulo = inputArquivo.closest('.section-card').find('.material-video-titulo, .material-arquivo-titulo').first();
				var titulo = (seletorTitulo.val() || '').trim();
				if (!titulo.length) {
					possuiErro = true;
				}
			});

			if (possuiErro) {
				swal({
					title: "Atencao!",
					text: "Informe o nome em cada card de video ou arquivo que possuir upload.",
					type: "error"
				});
				return false;
			}

			$('.salvar-material').hide();
			var formData = new FormData(this);
			$.ajax({
				type: "POST",
				url: "../../cadastro/salvamaterial",
				data: formData,
				processData: false,
				contentType: false,
				success: function(data) {
					if (data.trim().length > 0) {
						$('.salvar-material').show();
						swal({
							title: "Atencao!",
							text: data,
							type: "error"
						});
						return;
					}

					swal({
						title: "Sucesso!",
						text: "Configuracao da tela de material salva com sucesso.",
						type: "success"
					}, function() {
						carregarTela('../../cadastro/material');
					});
				},
				error: function() {
					$('.salvar-material').show();
					swal({
						title: "Atencao!",
						text: "Nao foi possivel salvar a configuracao da tela de material.",
						type: "error"
					});
				}
			});
		});
	});
</script>
