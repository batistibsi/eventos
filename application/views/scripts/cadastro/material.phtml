<div class="content-page">
	<div class="content-page__header">
		<h1 class="content-page__title">Configuração da Tela de Material</h1>
		<div class="content-page__toolbar">
			<button type="button" onclick="carregarTela('../../cadastro')" class="btn btn-primary"><i class="fa fa-arrow-left" aria-hidden="true"></i> Voltar</button>
		</div>
	</div>

	<form id="form-material-config" class="projeto-form" novalidate>
		<div class="section-card">
			<div class="section-header">
				<div>
					<h2 class="section-title">Cabecalho e video principal</h2>
					<p class="section-subtitle">Defina o texto principal e o link do video de destaque.</p>
				</div>
			</div>
			<div class="row">
				<div class="form-group col-md-12">
					<span><label for="material_titulo">Titulo da pagina: </label></span>
					<input class="form-control" name="material_titulo" id="material_titulo" maxlength="150" value="<?= $this->escape($registro['material_titulo'] ?? '') ?>" required>
				</div>
				<div class="form-group col-md-12">
					<span><label for="material_video_principal_link">Link do video principal: </label></span>
					<input class="form-control" name="material_video_principal_link" id="material_video_principal_link" value="<?= $this->escape($registro['material_video_principal_link'] ?? '') ?>" placeholder="https://www.youtube.com/watch?v=...">
				</div>
			</div>
		</div>

		<div class="section-card">
			<div class="section-header">
				<div>
					<h2 class="section-title">Videos secundarios</h2>
					<p class="section-subtitle">Use uma linha por card no formato: Titulo | URL</p>
				</div>
			</div>
			<div class="row">
				<div class="form-group col-md-12">
					<span><label for="material_videos_secundarios">Cards de video: </label></span>
					<textarea class="form-control" name="material_videos_secundarios" id="material_videos_secundarios" rows="7"><?= $this->escape($registro['material_videos_secundarios'] ?? '') ?></textarea>
				</div>
			</div>
		</div>

		<div class="section-card">
			<div class="section-header">
				<div>
					<h2 class="section-title">Arquivos e links</h2>
					<p class="section-subtitle">Arquivos e lista final tambem usam uma linha por item no formato: Titulo | URL</p>
				</div>
			</div>
			<div class="row">
				<div class="form-group col-md-6">
					<span><label for="material_arquivos">Cards de arquivos: </label></span>
					<textarea class="form-control" name="material_arquivos" id="material_arquivos" rows="6"><?= $this->escape($registro['material_arquivos'] ?? '') ?></textarea>
				</div>
				<div class="form-group col-md-6">
					<span><label for="material_links_lista">Lista de links: </label></span>
					<textarea class="form-control" name="material_links_lista" id="material_links_lista" rows="6"><?= $this->escape($registro['material_links_lista'] ?? '') ?></textarea>
				</div>
			</div>
		</div>

		<div class="section-actions">
			<button class="btn btn-success salvar-material"><i class="fa fa-floppy-o" aria-hidden="true"></i> Salvar configuração</button>
		</div>
	</form>
</div>

<script type="text/javascript">
	$(document).ready(function() {
		$('#form-material-config').submit(function(e) {
			e.preventDefault();

			if (!this.checkValidity()) {
				this.reportValidity();
				return false;
			}

			$('.salvar-material').hide();
			$.ajax({
				type: "POST",
				url: "../../cadastro/salvamaterial",
				data: $(this).serialize(),
				success: function(data) {
					if (data.trim().length > 0) {
						$('.salvar-material').show();
						swal({
							title: "Atencao!",
							text: data,
							type: "error"
						});
						return;
					}

					swal({
						title: "Sucesso!",
						text: "Configuracao da tela de material salva com sucesso.",
						type: "success"
					}, function() {
						carregarTela('../../cadastro/material');
					});
				},
				error: function() {
					$('.salvar-material').show();
					swal({
						title: "Atencao!",
						text: "Nao foi possivel salvar a configuracao da tela de material.",
						type: "error"
					});
				}
			});
		});
	});
</script>
