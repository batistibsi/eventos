<?php
$registro = !empty($this->registro) && is_array($this->registro) ? $this->registro : array();
$videos = array();
$linhasVideos = preg_split('/\r\n|\r|\n/', (string) ($registro['material_videos_secundarios'] ?? ''));
foreach ($linhasVideos as $linhaVideo) {
	$linhaVideo = trim((string) $linhaVideo);
	if ($linhaVideo === '') {
		continue;
	}

	$partesVideo = array_map('trim', explode('|', $linhaVideo, 2));
	$videos[] = array(
		'titulo' => $partesVideo[0] ?? '',
		'url' => $partesVideo[1] ?? ''
	);

	if (count($videos) >= 6) {
		break;
	}
}

for ($i = count($videos); $i < 6; $i++) {
	$videos[] = array(
		'titulo' => '',
		'url' => ''
	);
}

$arquivos = array();
$linhasArquivos = preg_split('/\r\n|\r|\n/', (string) ($registro['material_arquivos'] ?? ''));
foreach ($linhasArquivos as $linhaArquivo) {
	$linhaArquivo = trim((string) $linhaArquivo);
	if ($linhaArquivo === '') {
		continue;
	}

	$partesArquivo = array_map('trim', explode('|', $linhaArquivo, 2));
	$arquivos[] = array(
		'titulo' => $partesArquivo[0] ?? '',
		'url' => $partesArquivo[1] ?? ''
	);

	if (count($arquivos) >= 4) {
		break;
	}
}

for ($i = count($arquivos); $i < 4; $i++) {
	$arquivos[] = array(
		'titulo' => '',
		'url' => ''
	);
}
