<script type="text/javascript">
	$(document).ready(function() {
		$('#form-selos-config').submit(function(e) {
			e.preventDefault();

			$('.salvar-selos').hide();
			var formData = new FormData(this);
			$.ajax({
				type: "POST",
				url: "../../cadastro/salvaselos",
				data: formData,
				processData: false,
				contentType: false,
				success: function(data) {
					if (data.trim().length > 0) {
						$('.salvar-selos').show();
						swal({
							title: "Atencao!",
							text: data,
							type: "error"
						});
						return;
					}

					swal({
						title: "Sucesso!",
						text: "Configuracao dos selos salva com sucesso.",
						type: "success"
					}, function() {
						carregarTela('../../cadastro/selos');
					});
				},
				error: function() {
					$('.salvar-selos').show();
					swal({
						title: "Atencao!",
						text: "Nao foi possivel salvar a configuracao dos selos.",
						type: "error"
					});
				}
			});
		});
	});
</script>
