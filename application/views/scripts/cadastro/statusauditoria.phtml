<? $registros = isset($this->registros) && is_array($this->registros) ? $this->registros : array(); ?>
<div class="content-page">
	<div class="content-page__header">
		<h1 class="content-page__title">Status de auditoria</h1>
		<div class="content-page__toolbar">
			<button type="button" onclick="carregarTela('../../cadastro')" class="btn btn-primary"><i class="fa fa-arrow-left" aria-hidden="true"></i> Voltar</button>
		</div>
	</div>

	<div class="section-card">
		<div class="section-header">
			<div>
				<h2 class="section-title">Mensagens exibidas para a empresa</h2>
				<p class="section-subtitle">Edite o texto destacado que aparece no topo da tela de projetos do perfil da empresa.</p>
			</div>
		</div>

		<? if (count($registros)) : ?>
			<div class="table-responsive">
				<table class="table table-bordered table-hover align-middle mb-0">
					<thead>
						<tr>
							<th width="80">ID</th>
							<th width="260">Status</th>
							<th>Descricao</th>
							<th width="140">Acao</th>
						</tr>
					</thead>
					<tbody>
						<? foreach ($registros as $registro) : ?>
							<tr class="linha-status-auditoria">
								<td><?= (int) $registro['id_status_auditoria'] ?></td>
								<td>
									<strong><?= $this->escape($registro['nome']) ?></strong>
									<input type="hidden" name="id_status_auditoria" value="<?= (int) $registro['id_status_auditoria'] ?>">
								</td>
								<td>
									<textarea class="form-control" name="descricao" rows="3" maxlength="500" placeholder="Deixe em branco para nao exibir mensagem no topo da tela de projetos."><?= $this->escape($registro['descricao'] ?? '') ?></textarea>
								</td>
								<td>
									<button type="button" class="btn btn-primary btn-sm btn-block salvar-status-auditoria-linha">
										<i class="fa fa-floppy-o" aria-hidden="true"></i> Salvar
									</button>
								</td>
							</tr>
						<? endforeach; ?>
					</tbody>
				</table>
			</div>
		<? else : ?>
			<div class="alert alert-info mb-0">Nenhum status de auditoria cadastrado.</div>
		<? endif; ?>
	</div>
</div>

<script type="text/javascript">
	$(document).ready(function() {
		function salvarStatusAuditoria(payload, botao) {
			botao.prop('disabled', true);

			$.ajax({
				type: "POST",
				url: "../../cadastro/salvarstatusauditoria",
				data: payload,
				success: function(data) {
					if (data.trim().length > 0) {
						swal({
							title: "Atencao!",
							text: data,
							type: "error"
						});
						botao.prop('disabled', false);
						return;
					}

					swal({
						title: "Sucesso!",
						text: "Mensagem do status salva com sucesso.",
						type: "success"
					}, function() {
						carregarTela('../../cadastro/statusauditoria');
					});
				},
				error: function() {
					botao.prop('disabled', false);
					swal({
						title: "Atencao!",
						text: "Nao foi possivel salvar a mensagem do status.",
						type: "error"
					});
				}
			});
		}

		$('.salvar-status-auditoria-linha').click(function() {
			var linha = $(this).closest('.linha-status-auditoria');
			salvarStatusAuditoria(linha.find(':input').serialize(), $(this));
		});
	});
</script>
