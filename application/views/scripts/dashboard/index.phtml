<script type="text/javascript">
    $(document).ready(function() {
        $('.dashboard-action-card').on('click', function() {
            var link = ($(this).data('link') || '').toString().trim();
            if (!link.length || $(this).is(':disabled')) {
                return;
            }

            if (link.indexOf('../../') === 0) {
                carregarTela(link);
                return;
            }

            window.location.href = link;
        });
    });
</script>
