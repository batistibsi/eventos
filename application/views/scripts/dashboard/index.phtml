<?
$config = !empty($this->configDashboard) && is_array($this->configDashboard)
    ? $this->configDashboard
    : array();

$evento = !empty($this->eventoDashboard) && is_array($this->eventoDashboard)
    ? $this->eventoDashboard
    : false;

$inscricao = !empty($this->inscricaoDashboard) && is_array($this->inscricaoDashboard)
    ? $this->inscricaoDashboard
    : false;

$imagensCarrossel = array_values(array_filter(array_map(
    'trim',
    preg_split('/\r\n|\r|\n/', (string) ($config['dashboard_carrossel_imagens'] ?? ''))
)));

$formatarData = function ($valor) {
    if (empty($valor)) {
        return 'A definir';
    }

    return Util::getDiaDaSemana($valor) . ', ' . Util::formatData($valor);
};

$timeline = array(
    array('classe' => 'inscricao', 'titulo' => 'Inscrição', 'data' => $formatarData($evento['data_inscricao'] ?? null)),
    array('classe' => 'submissao', 'titulo' => 'Submissão', 'data' => $formatarData($evento['data_submissao'] ?? null)),
    array('classe' => 'correcao', 'titulo' => 'Correção', 'data' => $formatarData($evento['data_correcao'] ?? null)),
    array('classe' => 'resultado', 'titulo' => 'Resultado', 'data' => $formatarData($evento['data_resultado'] ?? null)),
    array('classe' => 'inscricao-summit', 'titulo' => 'Inscrição Summit', 'data' => $formatarData($evento['data_inscricao_summit'] ?? null)),
    array('classe' => 'summit', 'titulo' => 'Summit', 'data' => $formatarData($evento['data_summit'] ?? null))
);

$tituloDashboard = $config['dashboard_titulo'] ?? 'Programe-se';
$avisoDashboard = $config['dashboard_aviso_texto'] ?? '';
$linkInscricao = $inscricao
    ? '../../inscricao/detalhe?id_inscricao=' . (int) $inscricao['id_inscricao']
    : '';
?>
<div class="content-page dashboard-page">
    <div class="dashboard-showcase section-card">
        <h2 class="dashboard-showcase__title"><?= $this->escape($tituloDashboard) ?></h2>

        <div class="dashboard-showcase__top">
            <div class="dashboard-showcase__left">
                <div class="dashboard-journey" aria-label="Cronograma do evento">
                    <? foreach ($timeline as $indice => $item): ?>
                        <div class="dashboard-journey__step dashboard-journey__step--<?= $item['classe'] ?>">
                            <div class="dashboard-journey__marker">
                                <span><?= str_pad((string) ($indice + 1), 2, '0', STR_PAD_LEFT) ?></span>
                            </div>

                            <div class="dashboard-journey__card">
                                <span class="dashboard-journey__date"><?= $this->escape($item['data']) ?></span>
                                <strong class="dashboard-journey__title"><?= $this->escape($item['titulo']) ?></strong>
                            </div>
                        </div>
                    <? endforeach; ?>
                </div>
            </div>

            <div class="dashboard-showcase__right">
                <div class="dashboard-carousel-card">
                    <? if (count($imagensCarrossel)): ?>
                        <div id="dashboardCarousel" class="carousel slide dashboard-carousel" data-ride="carousel">
                            <ol class="carousel-indicators">
                                <? foreach ($imagensCarrossel as $indice => $imagem): ?>
                                    <li
                                        data-target="#dashboardCarousel"
                                        data-slide-to="<?= (int) $indice ?>"
                                        class="<?= $indice === 0 ? 'active' : '' ?>"
                                    ></li>
                                <? endforeach; ?>
                            </ol>

                            <div class="carousel-inner">
                                <? foreach ($imagensCarrossel as $indice => $imagem): ?>
                                    <div class="carousel-item <?= $indice === 0 ? 'active' : '' ?>">
                                        <img src="<?= $this->escape($imagem) ?>" alt="Banner <?= (int) ($indice + 1) ?>">
                                    </div>
                                <? endforeach; ?>
                            </div>
                            <? if (count($imagensCarrossel) > 1): ?>
                                <a class="carousel-control-prev" href="#dashboardCarousel" role="button" data-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                </a>
                                <a class="carousel-control-next" href="#dashboardCarousel" role="button" data-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                </a>
                            <? endif; ?>
                        </div>
                    <? else: ?>
                        <div class="dashboard-carousel__empty">Cadastre imagens no menu Cadastros para preencher este carrossel.</div>
                    <? endif; ?>
                </div>

                <div class="dashboard-actions-grid">
                    <button
                        type="button"
                        class="dashboard-action-card"
                        data-link="<?= $linkInscricao ?>"
                        <?= !$inscricao ? 'disabled' : '' ?>
                    >
                        <span class="dashboard-action-card__icon"><i class="fa fa-id-card-o" aria-hidden="true"></i></span>
                        <span class="dashboard-action-card__label">Detalhes da inscrição</span>
                    </button>

                    <button type="button" class="dashboard-action-card" data-link="../../dashboard/material">
                        <span class="dashboard-action-card__icon"><i class="fa fa-book" aria-hidden="true"></i></span>
                        <span class="dashboard-action-card__label">Material de apoio</span>
                    </button>
                </div>
            </div>
        </div>

        <div class="dashboard-showcase__footer">
            <div class="dashboard-notice-card">
                <?= nl2br($this->escape($avisoDashboard)) ?>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    $(document).ready(function() {
        $('.dashboard-action-card').on('click', function() {
            var link = ($(this).data('link') || '').toString().trim();

            if (!link.length || $(this).is(':disabled')) {
                return;
            }

            if (link.indexOf('../../') === 0) {
                carregarTela(link);
                return;
            }

            window.location.href = link;
        });
    });
</script>
