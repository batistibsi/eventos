 <script type="text/javascript">
     $(document).ready(function() {


         const cores = [
             '#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd',
             '#8c564b', '#e377c2', '#7f7f7f', '#bcbd22', '#17becf',
             '#393b79', '#637939', '#8c6d31', '#843c39', '#7b4173',
             '#3182bd', '#6baed6', '#9ecae1', '#e6550d', '#fd8d3c',
             '#fdae6b', '#31a354', '#74c476', '#a1d99b', '#756bb1',
             '#9e9ac8', '#bcbddc', '#636363', '#969696', '#bdbdbd',
             '#17a2b8', '#ffc107', '#dc3545', '#28a745', '#6f42c1',
             '#20c997', '#6610f2', '#fd7e14', '#343a40', '#adb5bd',
             '#198754', '#0dcaf0', '#6c757d', '#ffc107', '#f8f9fa',
             '#007bff', '#e83e8c', '#fdc86f', '#b24fce', '#009999'
         ];

         // Eixo X: meses do ano
         const meses = ["Jan", "Fev", "Mar", "Abr", "Mai", "Jun", "Jul", "Ago", "Set", "Out", "Nov", "Dez"];

         // Clientes (cada um vira um dataset)
         const clientesMes = JSON.parse('<?= json_encode(array_values($this->empresas)) ?>');

         // Dados fictícios: valores mensais consolidados por cliente (ex.: em R$ mil)
         const base = JSON.parse('<?= json_encode($this->dadosAno) ?>');

         let datasets = clientesMes.map((c, i) => ({
             label: c.titulo,
             data: base[c.id_empresa],
             backgroundColor: cores[i] + "B3", // ~70% opacidade
             borderColor: cores[i],
             borderWidth: 1,
             borderRadius: 4,
             barThickness: "flex"
         }));

         // Helpers para formatar como BRL (assumindo dados "em mil")
         const moedaBRL = new Intl.NumberFormat("pt-BR", {
             style: "decimal",
             currency: "BRL",
             maximumFractionDigits: 0
         });

         const formatValor = v => moedaBRL.format(v);

         // Cria gráfico (barras agrupadas — não empilhado)
         const ctxAno = document.getElementById("clientesMes").getContext("2d");
         new Chart(ctxAno, {
             type: "bar", // troque para "line" se preferir linhas por cliente
             data: {
                 labels: meses,
                 datasets: datasets
             },
             options: {
                 responsive: true,
                 maintainAspectRatio: false,
                 plugins: {
                     legend: {
                         position: "top",
                         labels: {
                             boxWidth: 16,
                             boxHeight: 16,
                             padding: 12
                         }
                     },
                     tooltip: {
                         mode: "index",
                         intersect: false,
                         callbacks: {
                             label: (ctx) => ` ${ctx.dataset.label}: ${formatValor(ctx.parsed.y ?? 0)}`,
                             footer: (items) => {
                                 const total = items.reduce((a, i) => a + (i.parsed.y ?? 0), 0);
                                 return ` Total do mês: ${formatValor(total)}`;
                             }
                         },
                         footerFont: {
                             weight: "bold"
                         }
                     }
                 },
                 scales: {
                     x: {
                         stacked: false,
                         grid: {
                             display: false
                         }
                     },
                     y: {
                         beginAtZero: true,
                         grid: {
                             color: "rgba(0,0,0,.06)"
                         },
                         ticks: {
                             callback: (v) => formatValor(v)
                         }
                     }
                 },
                 layout: {
                     padding: {
                         top: 8,
                         right: 8,
                         bottom: 8,
                         left: 8
                     }
                 }
             }
         });

         <? if (!$this->id_empresa): ?>
             const clientes = JSON.parse('<?= json_encode(array_values($this->clientes)) ?>');
             const categorias = JSON.parse('<?= json_encode(array_values($this->estatistica['formularios'])) ?>');

             const dados = JSON.parse('<?= json_encode($this->dados) ?>');

             datasets2 = categorias.map(p => ({
                 label: p.descricao,
                 data: dados[p.id_formulario],
                 backgroundColor: p.cor + "B3", // ~70% opacidade
                 borderColor: p.cor,
                 borderWidth: 1,
                 borderRadius: 6,
                 barThickness: "flex"
             }));

             const ctx = document.getElementById("stackedBar").getContext("2d");
             new Chart(ctx, {
                 type: "bar",
                 data: {
                     labels: clientes,
                     datasets: datasets2
                 },
                 options: {
                     responsive: true,
                     maintainAspectRatio: false, // ⬅️ com altura controlada pelo contêiner
                     plugins: {
                         legend: {
                             position: "top"
                         },
                         tooltip: {
                             mode: "index",
                             intersect: false,
                             callbacks: {
                                 label: (ctx) => ` ${ctx.dataset.label}: ${formatValor(ctx.parsed.y ?? 0)}`,
                                 footer: (items) => ` Total: ${formatValor(items.reduce((a,i)=>a+(i.parsed.y??0),0))}`
                             }
                         }
                     },
                     scales: {
                         x: {
                             stacked: true,
                             grid: {
                                 display: false
                             }
                         },
                         y: {
                             stacked: true,
                             beginAtZero: true
                         }
                     }
                 }
             });

         <? endif; ?>

         var id_empresa = <?= $this->id_empresa ?>;

         var inicio = '<?= $this->inicio ?>';
         var fim = '<?= $this->fim ?>';

         $('#id_empresa').on('change', function() {
             id_empresa = $(this).val();
             carregarTela('../../dashboard?id_empresa=' + id_empresa + '&inicio=' + inicio + '&fim=' + fim);
         });

         let periodo = $('#periodo').daterangepicker({
             startDate: new Date('<?= $this->inicio ?> 00:00:00'),
             endDate: new Date('<?= $this->fim ?> 23:59:59'),
             ranges: {
                 'Hoje': [moment(), moment()],
                 'Ontem': [moment().subtract(1, 'days'), moment().subtract(1, 'days')],
                 'Últimos 7 dias': [moment().subtract(6, 'days'), moment()],
                 'Semana Atual': [moment().clone().startOf('isoWeek'), moment().clone().endOf('isoWeek')],
                 'Semana Passada': [moment().clone().subtract(1, 'weeks').startOf('isoWeek'), moment().clone().subtract(1, 'weeks').endOf('isoWeek')],
                 'Últimos 30 dias': [moment().subtract(29, 'days'), moment()],
                 'Mês Atual': [moment().startOf('month'), moment().endOf('month')],
                 'Mês Passado': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')]
             },
             "locale": {
                 format: 'DD/MM/YYYY',
                 "separator": " até ",
                 "applyLabel": "Aplicar",
                 "cancelLabel": "Cancelar",
                 "fromLabel": "De",
                 "toLabel": "Até",
                 "customRangeLabel": "Selecionar Data",
                 "daysOfWeek": [
                     "Dom",
                     "Seg",
                     "Ter",
                     "Qua",
                     "Qui",
                     "Sex",
                     "Sáb"
                 ],
                 "monthNames": [
                     "Janeiro",
                     "Fevereiro",
                     "Março",
                     "Abril",
                     "Maio",
                     "Junho",
                     "Julho",
                     "Agosto",
                     "Setembro",
                     "Outubro",
                     "Novembro",
                     "Dezembro"
                 ],
                 "firstDay": 0
             }
         }, function(start, end) {
             inicio = start.format('YYYY-MM-DD');
             fim = end.format('YYYY-MM-DD');
             carregarTela('../../dashboard?id_empresa=' + id_empresa + '&inicio=' + inicio + '&fim=' + fim);
         });

     });
 </script>