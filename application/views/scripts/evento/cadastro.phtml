<script type="text/javascript">
	$(document).ready(function() {
		$('#titulo').focus();

		$("#formulario").submit(function(e) {
			e.preventDefault();

			if (!this.checkValidity()) {
				this.reportValidity();
				return false;
			}

			$('.salvar').hide();
			$.ajax({
				type: "POST",
				url: "../../evento/salvar",
				data: $("#formulario").serialize(),
				success: function(data) {
					if (data.trim().length > 0) {
						$('.salvar').show();
						swal({
							title: "Atencao!",
							text: data,
							type: "error"
						});
					} else {
						carregarTela('../../evento');
					}
				},
				error: function() {
					$('.salvar').show();
					swal({
						title: "Atencao!",
						text: "Nao foi possivel salvar o evento.",
						type: "error"
					});
				}
			});
		});
	});
</script>
