<?
    $inscricao = $this->registro;
    $statusDisponiveis = isset($this->statusDisponiveis) && is_array($this->statusDisponiveis) ? $this->statusDisponiveis : [];
    $statusAtual = strtoupper(trim((string) ($inscricao['status'] ?? '')));

    if ($statusAtual !== '' && !in_array($statusAtual, $statusDisponiveis, true)) {
        $statusDisponiveis[] = $statusAtual;
    }

    $valorOuPadrao = function ($valor, $padrao = 'Não informado') {
        if ($valor === null) return $padrao;

        $valor = trim((string) $valor);
        return $valor !== '' ? $valor : $padrao;
    };

    $formatarDocumento = function ($numero, $tipo = 'cpf') use ($valorOuPadrao) {
        $numero = preg_replace('/\D/', '', (string) $numero);

        if ($tipo === 'cpf' && strlen($numero) === 11) {
            return Util::mask($numero, '###.###.###-##');
        }

        if ($tipo === 'cnpj' && strlen($numero) === 14) {
            return Util::mask($numero, '##.###.###/####-##');
        }

        return $valorOuPadrao($numero);
    };

    $formatarTelefone = function ($telefone) use ($valorOuPadrao) {
        $telefone = preg_replace('/\D/', '', (string) $telefone);

        if ($telefone === '') return $valorOuPadrao($telefone);

        return Util::mascaraTelefone($telefone);
    };

    $formatarBooleano = function ($valor) {
        $valor = filter_var($valor, FILTER_VALIDATE_BOOLEAN, FILTER_NULL_ON_FAILURE);
        return $valor ? 'Sim' : 'Não';
    };

    $formatarDataHora = function ($valor) {
        if (empty($valor)) {
            return 'Não informado';
        }

        return Util::formatData($valor) . ' ' . Util::formatHora($valor);
    };

    $representantes = [
        [
            'titulo' => 'Representante 1',
            'nome' => $inscricao['representante_1_nome'] ?? null,
            'email' => $inscricao['representante_1_email'] ?? null,
            'telefone' => $inscricao['representante_1_telefone'] ?? null
        ],
        [
            'titulo' => 'Representante 2',
            'nome' => $inscricao['representante_2_nome'] ?? null,
            'email' => $inscricao['representante_2_email'] ?? null,
            'telefone' => $inscricao['representante_2_telefone'] ?? null
        ],
        [
            'titulo' => 'Representante 3',
            'nome' => $inscricao['representante_3_nome'] ?? null,
            'email' => $inscricao['representante_3_email'] ?? null,
            'telefone' => $inscricao['representante_3_telefone'] ?? null
        ]
    ];

    $logo = !empty($inscricao['logo_organizacao']) ? '../../download.php?arquivo=' . urlencode($inscricao['logo_organizacao']) : null;
    $extensaoLogo = !empty($inscricao['logo_organizacao']) ? strtolower(pathinfo($inscricao['logo_organizacao'], PATHINFO_EXTENSION)) : '';
    $logoEhImagem = in_array($extensaoLogo, ['png', 'jpg', 'jpeg', 'gif', 'webp'], true);
?>

