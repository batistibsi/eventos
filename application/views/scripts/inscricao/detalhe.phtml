<script type="text/javascript">
    $(document).ready(function() {
        function extrairDigitos(valor) {
            return (valor || '').replace(/\D/g, '');
        }

        function aplicarMascaraTelefone(valor) {
            const digitos = extrairDigitos(valor).slice(0, 11);

            if (digitos.length <= 2) {
                return digitos.length ? '(' + digitos : '';
            }

            if (digitos.length <= 6) {
                return '(' + digitos.slice(0, 2) + ') ' + digitos.slice(2);
            }

            if (digitos.length <= 10) {
                return '(' + digitos.slice(0, 2) + ') ' + digitos.slice(2, 6) + '-' + digitos.slice(6);
            }

            return '(' + digitos.slice(0, 2) + ') ' + digitos.slice(2, 7) + '-' + digitos.slice(7);
        }

        function telefoneValido(valor) {
            const digitos = extrairDigitos(valor);
            return digitos.length === 10 || digitos.length === 11;
        }

        function emailValido(valor) {
            if (!valor) {
                return false;
            }

            return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(valor);
        }

        function decodificarTextoSwal(valor) {
            const texto = (valor || '').trim();

            if (!texto) {
                return '';
            }

            return $('<textarea/>').html(texto).text();
        }

        function validarTelefoneCampo(campo) {
            if (campo.disabled || campo.readOnly) {
                return true;
            }

            const valor = campo.value.trim();

            if (!valor) {
                campo.setCustomValidity('');
                return true;
            }

            campo.value = aplicarMascaraTelefone(valor);
            const valido = telefoneValido(campo.value);
            campo.setCustomValidity(valido ? '' : 'Informe um telefone válido com DDD.');
            return valido;
        }

        function validarEmailCampo(campo) {
            if (campo.disabled || campo.readOnly) {
                return true;
            }

            const valor = campo.value.trim();
            campo.value = valor;

            if (!valor) {
                campo.setCustomValidity('');
                return true;
            }

            const valido = emailValido(valor);
            campo.setCustomValidity(valido ? '' : 'Informe um e-mail válido.');
            return valido;
        }

        $('#form-status-inscricao').submit(function(e) {
            e.preventDefault();

            $('.salvar-status').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: "../../inscricao/alterarstatus",
                data: $(this).serialize(),
                success: function(data) {
                    if (data.trim().length > 0) {
                        swal({
                            title: "Atenção!",
                            text: decodificarTextoSwal(data),
                            type: "error"
                        });
                    } else {
                        swal({
                            title: "Sucesso!",
                            text: "Status alterado com sucesso.",
                            type: "success"
                        });
                    }

                    $('.salvar-status').prop('disabled', false);
                },
                error: function() {
                    $('.salvar-status').prop('disabled', false);

                    swal({
                        title: "Atenção!",
                        text: "Não foi possível alterar o status.",
                        type: "error"
                    });
                }
            });
        });

        $('#form-auditor-inscricao').submit(function(e) {
            e.preventDefault();

            $('.salvar-auditor').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: "../../inscricao/definirauditor",
                data: $(this).serialize(),
                success: function(data) {
                    if (data.trim().length > 0) {
                        swal({
                            title: "Atenção!",
                            text: decodificarTextoSwal(data),
                            type: "error"
                        });
                    } else {
                        swal({
                            title: "Sucesso!",
                            text: "Auditor definido com sucesso.",
                            type: "success"
                        });
                    }

                    $('.salvar-auditor').prop('disabled', false);
                },
                error: function() {
                    $('.salvar-auditor').prop('disabled', false);

                    swal({
                        title: "Atenção!",
                        text: "Não foi possível definir o auditor.",
                        type: "error"
                    });
                }
            });
        });

        $('#form-encontros-formacao-inscricao').submit(function(e) {
            e.preventDefault();

            $('.salvar-encontros-formacao').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: "../../inscricao/salvarconfirmacaoencontrosformacao",
                data: $(this).serialize(),
                success: function(data) {
                    if (data.trim().length > 0) {
                        swal({
                            title: "Atenção!",
                            text: decodificarTextoSwal(data),
                            type: "error"
                        });
                    } else {
                        swal({
                            title: "Sucesso!",
                            text: "Confirmações dos encontros salvas com sucesso.",
                            type: "success"
                        });
                    }

                    $('.salvar-encontros-formacao').prop('disabled', false);
                },
                error: function() {
                    $('.salvar-encontros-formacao').prop('disabled', false);

                    swal({
                        title: "Atenção!",
                        text: "Não foi possível salvar as confirmações dos encontros.",
                        type: "error"
                    });
                }
            });
        });

        $('#form-forma-pagamento-inscricao').submit(function(e) {
            e.preventDefault();

            $('.salvar-forma-pagamento-inscricao').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: "../../inscricao/salvarformapagamento",
                data: $(this).serialize(),
                success: function(data) {
                    if (data.trim().length > 0) {
                        swal({
                            title: "Atenção!",
                            text: decodificarTextoSwal(data),
                            type: "error"
                        });
                    } else {
                        swal({
                            title: "Sucesso!",
                            text: "Forma de pagamento salva com sucesso.",
                            type: "success"
                        });
                    }

                    $('.salvar-forma-pagamento-inscricao').prop('disabled', false);
                },
                error: function() {
                    $('.salvar-forma-pagamento-inscricao').prop('disabled', false);

                    swal({
                        title: "Atenção!",
                        text: "Não foi possível salvar a forma de pagamento.",
                        type: "error"
                    });
                }
            });
        });

        $('#form-evento-inscricao').submit(function(e) {
            e.preventDefault();

            $('.salvar-evento-inscricao').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: "../../inscricao/salvarevento",
                data: $(this).serialize(),
                success: function(data) {
                    if (data.trim().length > 0) {
                        swal({
                            title: "Atenção!",
                            text: decodificarTextoSwal(data),
                            type: "error"
                        });
                    } else {
                        swal({
                            title: "Sucesso!",
                            text: "Turma alterada com sucesso.",
                            type: "success"
                        }, function() {
                            carregarTela('../../inscricao/detalhe?id_inscricao=<?= (int) ($inscricao['id_inscricao'] ?? 0) ?>');
                        });
                    }

                    $('.salvar-evento-inscricao').prop('disabled', false);
                },
                error: function() {
                    $('.salvar-evento-inscricao').prop('disabled', false);

                    swal({
                        title: "Atenção!",
                        text: "Não foi possível salvar a turma da inscrição.",
                        type: "error"
                    });
                }
            });
        });

        $('.representante-telefone').mask('(00) 00000-0000');
        $('.summit-telefone').mask('(00) 00000-0000');

        $(document).on('input blur', '.representante-telefone, .summit-telefone', function() {
            validarTelefoneCampo(this);
        });

        $(document).on('input blur', 'input[type="email"]', function() {
            validarEmailCampo(this);
        });

        $('#form-representantes-inscricao').submit(function(e) {
            e.preventDefault();

            const form = this;
            let valido = true;

            $(form).find('.representante-telefone').each(function() {
                if (!validarTelefoneCampo(this)) {
                    valido = false;
                }
            });

            $(form).find('input[type="email"]').each(function() {
                if (!validarEmailCampo(this)) {
                    valido = false;
                }
            });

            if (!valido || !form.checkValidity()) {
                form.reportValidity();
                return;
            }

            $('.salvar-representantes-inscricao').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: "../../inscricao/salvarrepresentantes",
                data: $(this).serialize(),
                success: function(data) {
                    if (data.trim().length > 0) {
                        swal({
                            title: "Atenção!",
                            text: decodificarTextoSwal(data),
                            type: "error"
                        });
                    } else {
                        swal({
                            title: "Sucesso!",
                            text: "Representantes salvos com sucesso.",
                            type: "success"
                        });
                    }

                    $('.salvar-representantes-inscricao').prop('disabled', false);
                },
                error: function() {
                    $('.salvar-representantes-inscricao').prop('disabled', false);

                    swal({
                        title: "Atenção!",
                        text: "Não foi possível salvar os representantes.",
                        type: "error"
                    });
                }
            });
        });

        $('#form-summit-inscricao').submit(function(e) {
            e.preventDefault();

            const form = this;
            let valido = true;

            $(form).find('.summit-telefone').each(function() {
                if (!validarTelefoneCampo(this)) {
                    valido = false;
                }
            });

            if (!valido || !form.checkValidity()) {
                form.reportValidity();
                return;
            }

            $('.salvar-summit-inscricao').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: "../../inscricao/salvarsummit",
                data: $(this).serialize(),
                success: function(data) {
                    if (data.trim().length > 0) {
                        swal({
                            title: "Atenção!",
                            text: decodificarTextoSwal(data),
                            type: "error"
                        });
                    } else {
                        swal({
                            title: "Sucesso!",
                            text: "Inscrições do Summit salvas com sucesso.",
                            type: "success"
                        });
                    }

                    $('.salvar-summit-inscricao').prop('disabled', false);
                },
                error: function() {
                    $('.salvar-summit-inscricao').prop('disabled', false);

                    swal({
                        title: "Atenção!",
                        text: "Não foi possível salvar as inscrições do Summit.",
                        type: "error"
                    });
                }
            });
        });

        if (window.formularioProtegido) {
            window.setTimeout(function() {
                window.formularioProtegido.limparEstado();
            }, 0);
        }
    });
</script>
