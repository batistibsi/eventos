    $auditores = isset($this->auditores) && is_array($this->auditores) ? $this->auditores : [];
    $formasPagamento = isset($this->formasPagamento) && is_array($this->formasPagamento) ? $this->formasPagamento : [];
    $eventosDisponiveis = isset($this->eventosDisponiveis) && is_array($this->eventosDisponiveis) ? $this->eventosDisponiveis : [];
