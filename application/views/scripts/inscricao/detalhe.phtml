<script type="text/javascript">
    $(document).ready(function() {
        $('#form-status-inscricao').submit(function(e) {
            e.preventDefault();

            $('.salvar-status').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: "../../inscricao/alterarstatus",
                data: $(this).serialize(),
                success: function(data) {
                    if (data.trim().length > 0) {
                        swal({
                            title: "Atencao!",
                            text: data,
                            type: "error"
                        });
                    } else {
                        swal({
                            title: "Sucesso!",
                            text: "Status alterado com sucesso.",
                            type: "success"
                        });
                    }

                    $('.salvar-status').prop('disabled', false);
                },
                error: function() {
                    $('.salvar-status').prop('disabled', false);

                    swal({
                        title: "Atencao!",
                        text: "Nao foi possivel alterar o status.",
                        type: "error"
                    });
                }
            });
        });
    });
</script>
