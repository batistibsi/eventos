    $dataSummitFormatada = !empty($inscricao['data_inscricao_summit']) ? Util::formatData($inscricao['data_inscricao_summit']) : 'Não informada';
    $prazoSummitEncerrado = true;

    if (!empty($inscricao['data_inscricao_summit'])) {
        try {
            $prazoSummitEncerrado = (new DateTime(date('Y-m-d'))) > (new DateTime(date('Y-m-d', strtotime($inscricao['data_inscricao_summit']))));
        } catch (Exception $e) {
            $prazoSummitEncerrado = true;
        }
    }

    $summitSlots = [];
    for ($i = 1; $i <= 3; $i++) {
        $registroSummit = $summitInscricoes[$i - 1] ?? [];
        $summitSlots[] = [
            'indice' => $i,
