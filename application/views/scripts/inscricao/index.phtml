<? $statusBadgeClass = function ($status) {
    $status = strtoupper(trim((string) $status));
    if ($status === '') {
        $status = 'NAO INFORMADO';
    }

    return 'status-badge--' . strtolower(str_replace([' ', '_'], '-', $status));
}; ?>
