				$('#empresa_vinculada_vazio').text('Nenhuma inscrição vinculada encontrada para este usuário.').show();
				return;
			}

			$('#empresa_vinculada_dados').show();
			$('#empresa_vinculada_vazio').hide();
			$('#empresa_nome_organizacao').text(empresa.nome_organizacao || '-');
