<script type="text/javascript">
	$(document).ready(function() {
		$('#nome').focus();
		$('select#id_usuario, select#id_evento').select2({
			theme: 'bootstrap4',
			language: 'pt-BR',
			width: '100%'
		});

		var arquivosExistentes = <?= $registro && !empty($registro['arquivos']) ? count($registro['arquivos']) : 0 ?>;
		var dropzone = new Dropzone('#projeto-dropzone', {
			url: '#',
			autoProcessQueue: false,
			uploadMultiple: true,
			parallelUploads: 5,
			maxFiles: 5,
			maxFilesize: 100,
			addRemoveLinks: true,
			paramName: 'evidencias',
			clickable: true,
			acceptedFiles: '.pdf,.png,.jpg,.jpeg,.gif,.webp,.mp4,.mov,.avi,.wmv,.mp3,.wav,.txt,.doc,.docx,.xls,.xlsx,.csv,.ppt,.pptx,.zip,.rar',
			dictDefaultMessage: 'Arraste arquivos aqui ou clique para selecionar',
			dictRemoveFile: 'Remover',
			dictFileTooBig: 'Arquivo muito grande. Tamanho maximo: 100 MB.',
			dictInvalidFileType: 'Tipo de arquivo nao permitido.',
			init: function() {
				var dz = this;
				<? if ($registro && !empty($registro['arquivos'])): ?>
					<? foreach ($registro['arquivos'] as $arquivo): ?>
						(function() {
							var mockFile = {
								name: <?= json_encode($arquivo['nome_original']) ?>,
								size: <?= (int) ($arquivo['tamanho_bytes'] ?: 0) ?>,
								accepted: true,
								existing: true,
								serverId: <?= (int) $arquivo['id_projeto_arquivo'] ?>,
								url: '../../download.php?arquivo=<?= urlencode($arquivo['caminho_arquivo']) ?>'
							};
							dz.emit('addedfile', mockFile);
							dz.emit('complete', mockFile);
							if (mockFile.previewElement) {
								$(mockFile.previewElement).addClass('dz-success dz-complete dz-existing-file');
								$(mockFile.previewElement).find('.dz-filename span').wrap('<a target="_blank" href="' + mockFile.url + '"></a>');
							}
							dz.files.push(mockFile);
						})();
					<? endforeach; ?>
				<? endif; ?>

				dz.on('maxfilesexceeded', function(file) {
					dz.removeFile(file);
					swal({
						title: 'Atencao!',
						text: 'O projeto pode ter no maximo 5 arquivos de evidencia.',
						type: 'error'
					});
				});

				dz.on('removedfile', function(file) {
					if (!file || !file.existing || !file.serverId) {
						return;
					}

					$.ajax({
						type: 'POST',
						url: '../../projeto/removerarquivo',
						data: { id: file.serverId },
						success: function(data) {
							if (data.trim().length > 0) {
								swal({
									title: 'Atencao!',
									text: data,
									type: 'error'
								});
								carregarTela('../../projeto/cadastro?id_projeto=' + $('#id_projeto').val());
							} else {
								arquivosExistentes = Math.max(0, arquivosExistentes - 1);
							}
						},
						error: function() {
							swal({
								title: 'Atencao!',
								text: 'Nao foi possivel remover o arquivo.',
								type: 'error'
							});
							carregarTela('../../projeto/cadastro?id_projeto=' + $('#id_projeto').val());
						}
					});
				});
			}
		});

		$("#formulario").submit(function(e) {
			e.preventDefault();

			if (!this.checkValidity()) {
				this.reportValidity();
				return false;
			}

			var arquivosSelecionados = dropzone.getAcceptedFiles().filter(function(file) {
				return !file.existing;
			}).length;
			if ((arquivosSelecionados + arquivosExistentes) > 5) {
				swal({
					title: "Atencao!",
					text: "O projeto pode ter no maximo 5 arquivos de evidencia.",
					type: "error"
				});
				return false;
			}

			$('.salvar').hide();
			var formData = new FormData(this);
			dropzone.getAcceptedFiles().forEach(function(file) {
				if (!file.existing) {
					formData.append('evidencias[]', file, file.name);
				}
			});
			$.ajax({
				type: "POST",
				url: "../../projeto/salvar",
				data: formData,
				processData: false,
				contentType: false,
				success: function(data) {
					if (data.trim().length > 0) {
						$('.salvar').show();
						swal({
							title: "Atencao!",
							text: data,
							type: "error"
						});
					} else {
						carregarTela('../../projeto');
					}
				},
				error: function() {
					$('.salvar').show();
					swal({
						title: "Atencao!",
						text: "Nao foi possivel salvar o projeto.",
						type: "error"
					});
				}
			});
		});
	});
</script>
