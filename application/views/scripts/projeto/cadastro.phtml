		function atualizarEmpresaVinculada() {
			var idUsuario = $('#id_usuario').val();
			var empresa = empresasPorUsuario[idUsuario] || { vazio: true };

			if (empresa.vazio) {
				$('#empresa_vinculada_dados').hide();
				$('#empresa_nome_organizacao').text('');
				$('#empresa_cnpj').text('');
				$('#empresa_nome_certificado').text('');
				$('#empresa_numero_colaboradores').text('');
