				return false;
			}

			$('.salvar').hide();
			var formData = new FormData(this);
			dropzone.getAcceptedFiles().forEach(function(file) {
				if (!file.existing) {
					formData.append('evidencias[]', file, file.name);
				}
			});
			dropzoneItens.getAcceptedFiles().forEach(function(file) {
				if (!file.existing) {
					formData.append('evidencias_itens[]', file, file.name);
				}
			});
			dropzonePessoas.getAcceptedFiles().forEach(function(file) {
				if (!file.existing) {
					formData.append('evidencias_pessoas[]', file, file.name);
				}
			});
			dropzoneParceiros.getAcceptedFiles().forEach(function(file) {
				if (!file.existing) {
					formData.append('evidencias_parceiros[]', file, file.name);
				}
			});
			$.ajax({
				type: "POST",
				url: "../../projeto/salvar",
				data: formData,
				processData: false,
				contentType: false,
				success: function(data) {
					if (data.trim().length > 0) {
						$('.salvar').show();
						swal({
							title: "Atenção!",
							text: data,
							type: "error"
						});
					} else {
						swal({
							title: "Sucesso!",
							text: <?= json_encode($mensagemSucessoProjeto, JSON_UNESCAPED_UNICODE) ?>,
							type: "success"
						}, function() {
							carregarTela('../../projeto');
						});
					}
				},
				error: function() {
					$('.salvar').show();
					swal({
						title: "Atenção!",
						text: "Não foi possível salvar o projeto.",
						type: "error"
					});
				}
			});
		});
	});
</script>
