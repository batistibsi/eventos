<script type="text/javascript">
	$(document).ready(function() {
		$('#nome').focus();
		$('select#id_usuario').select2({
			theme: 'bootstrap4',
			language: 'pt-BR',
			width: '100%'
		});

		<? if ($this->permissao == 1): ?>
		var eventosPorUsuario = <?= json_encode($this->eventosPorUsuario, JSON_UNESCAPED_UNICODE) ?>;
		var empresasPorUsuario = <?= json_encode($this->empresasPorUsuario, JSON_UNESCAPED_UNICODE) ?>;

		function atualizarEventoVinculado() {
			var idUsuario = $('#id_usuario').val();
			var evento = eventosPorUsuario[idUsuario] || { id_evento: '', label: 'Nenhuma inscrição vinculada encontrada para este usuário.' };
			$('#id_evento').val(evento.id_evento || '');
			$('#evento_vinculado_label').val(evento.label || '');
		}

		function atualizarEmpresaVinculada() {
			var idUsuario = $('#id_usuario').val();
			var empresa = empresasPorUsuario[idUsuario] || { vazio: true };

			if (empresa.vazio) {
				$('#empresa_vinculada_dados').hide();
				$('#empresa_nome_organizacao').text('');
				$('#empresa_cnpj').text('');
				$('#empresa_nome_certificado').text('');
				$('#empresa_numero_colaboradores').text('');
				$('#empresa_responsavel_inscricao').text('');
				$('#empresa_contato_inscricao').html('');
				$('#empresa_vinculada_vazio').text('Nenhuma inscrição vinculada encontrada para este usuário.').show();
				return;
			}

			$('#empresa_vinculada_dados').show();
			$('#empresa_vinculada_vazio').hide();
			$('#empresa_nome_organizacao').text(empresa.nome_organizacao || '-');
			$('#empresa_cnpj').text(empresa.cnpj || '-');
			$('#empresa_nome_certificado').text(empresa.nome_certificado || '-');
			$('#empresa_numero_colaboradores').text(empresa.numero_colaboradores || '0');
			$('#empresa_responsavel_inscricao').text(empresa.nome || '-');
			var contato = empresa.email || '-';
			if (empresa.telefone) {
				contato += '<br>' + empresa.telefone;
			}
			$('#empresa_contato_inscricao').html(contato);
		}

		$('#id_usuario').on('change', atualizarEventoVinculado);
		$('#id_usuario').on('change', atualizarEmpresaVinculada);
		atualizarEventoVinculado();
		atualizarEmpresaVinculada();
		<? endif; ?>

		var arquivosExistentes = <?= $registro && !empty($registro['arquivos']) ? count($registro['arquivos']) : 0 ?>;
		var dropzone = new Dropzone('#projeto-dropzone', {
			url: '#',
			autoProcessQueue: false,
			uploadMultiple: true,
			parallelUploads: 5,
			maxFiles: 5,
			maxFilesize: 100,
			addRemoveLinks: true,
			paramName: 'evidencias',
			clickable: true,
			acceptedFiles: '.pdf,.png,.jpg,.jpeg,.gif,.webp,.mp4,.mov,.avi,.wmv,.mp3,.wav,.txt,.doc,.docx,.xls,.xlsx,.csv,.ppt,.pptx,.zip,.rar',
			dictDefaultMessage: 'Arraste arquivos aqui ou clique para selecionar',
			dictRemoveFile: 'Remover',
			dictFileTooBig: 'Arquivo muito grande. Tamanho máximo: 100 MB.',
			dictInvalidFileType: 'Tipo de arquivo não permitido.',
			init: function() {
				var dz = this;
				var extensoesImagem = ['png', 'jpg', 'jpeg', 'gif', 'webp'];

				function renderizarPreviewExistente(mockFile) {
					if (!mockFile.previewElement) {
						return;
					}

					var $preview = $(mockFile.previewElement);
					var extensao = (mockFile.name.split('.').pop() || '').toLowerCase();
					var $image = $preview.find('.dz-image');

					$preview.addClass('dz-success dz-complete dz-existing-file');
					$preview.find('.dz-filename span').wrap('<a target="_blank" href="' + mockFile.url + '"></a>');

					if (extensoesImagem.indexOf(extensao) !== -1) {
						dz.emit('thumbnail', mockFile, mockFile.url);
						return;
					}

					$image.html('<div class="dropzone-file-icon">' + (extensao ? extensao.toUpperCase() : 'ARQ') + '</div>');
				}

				<? if ($registro && !empty($registro['arquivos'])): ?>
					<? foreach ($registro['arquivos'] as $arquivo): ?>
						(function() {
							var mockFile = {
								name: <?= json_encode($arquivo['nome_original']) ?>,
								size: <?= (int) ($arquivo['tamanho_bytes'] ?: 0) ?>,
								accepted: true,
								existing: true,
								serverId: <?= (int) $arquivo['id_projeto_arquivo'] ?>,
								url: '../../download.php?arquivo=<?= urlencode($arquivo['caminho_arquivo']) ?>'
							};
							dz.emit('addedfile', mockFile);
							renderizarPreviewExistente(mockFile);
							dz.emit('complete', mockFile);
							dz.files.push(mockFile);
						})();
					<? endforeach; ?>
				<? endif; ?>

				dz.on('maxfilesexceeded', function(file) {
					dz.removeFile(file);
					swal({
						title: 'Atenção!',
						text: 'O projeto pode ter no máximo 5 arquivos de evidência.',
						type: 'error'
					});
				});

				dz.on('removedfile', function(file) {
					if (!file || !file.existing || !file.serverId) {
						return;
					}

					$.ajax({
						type: 'POST',
						url: '../../projeto/removerarquivo',
						data: { id: file.serverId },
						success: function(data) {
							if (data.trim().length > 0) {
								swal({
									title: 'Atenção!',
									text: data,
									type: 'error'
								});
								carregarTela('../../projeto/cadastro?id_projeto=' + $('#id_projeto').val());
							} else {
								arquivosExistentes = Math.max(0, arquivosExistentes - 1);
							}
						},
						error: function() {
							swal({
								title: 'Atenção!',
								text: 'Não foi possível remover o arquivo.',
								type: 'error'
							});
							carregarTela('../../projeto/cadastro?id_projeto=' + $('#id_projeto').val());
						}
					});
				});
			}
		});

		$("#formulario").submit(function(e) {
			e.preventDefault();

			if (!this.checkValidity()) {
				this.reportValidity();
				return false;
			}

			var arquivosSelecionados = dropzone.getAcceptedFiles().filter(function(file) {
				return !file.existing;
			}).length;
			if ((arquivosSelecionados + arquivosExistentes) > 5) {
				swal({
					title: "Atenção!",
					text: "O projeto pode ter no máximo 5 arquivos de evidência.",
					type: "error"
				});
				return false;
			}

			$('.salvar').hide();
			var formData = new FormData(this);
			dropzone.getAcceptedFiles().forEach(function(file) {
				if (!file.existing) {
					formData.append('evidencias[]', file, file.name);
				}
			});
			$.ajax({
				type: "POST",
				url: "../../projeto/salvar",
				data: formData,
				processData: false,
				contentType: false,
				success: function(data) {
					if (data.trim().length > 0) {
						$('.salvar').show();
						swal({
							title: "Atenção!",
							text: data,
							type: "error"
						});
					} else {
						carregarTela('../../projeto');
					}
				},
				error: function() {
					$('.salvar').show();
					swal({
						title: "Atenção!",
						text: "Não foi possível salvar o projeto.",
						type: "error"
					});
				}
			});
		});
	});
</script>
