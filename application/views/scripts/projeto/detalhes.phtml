<? $view = $this; ?>
<? $avaliacaoPadrao = function ($campo) use ($avaliacoes) {
	if (!isset($avaliacoes[$campo]) || !is_array($avaliacoes[$campo])) {
		return array('aprovado' => null, 'comentario' => '');
	}
	return array(
		'aprovado' => array_key_exists('aprovado', $avaliacoes[$campo]) ? $avaliacoes[$campo]['aprovado'] : null,
		'comentario' => isset($avaliacoes[$campo]['comentario']) ? $avaliacoes[$campo]['comentario'] : ''
	);
}; ?>
