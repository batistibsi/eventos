<script type="text/javascript">
	$(document).ready(function() {
		function atualizarCoresParecer() {
			$('.projeto-avaliacao-box').each(function() {
				var $box = $(this);
				var valor = $box.find('input[type="radio"]:checked').val();

				$box.removeClass('is-aprovado is-reprovado is-pendente');

				if (valor === '1') {
					$box.addClass('is-aprovado');
				} else if (valor === '0') {
					$box.addClass('is-reprovado');
				} else {
					$box.addClass('is-pendente');
				}
			});
		}

		atualizarCoresParecer();

		$('.projeto-avaliacao-box input[type="radio"]').on('change', function() {
			atualizarCoresParecer();
		});

		$('#form-avaliacao-projeto').submit(function(e) {
			e.preventDefault();

			$('.salvar-avaliacao-projeto').prop('disabled', true);

			$.ajax({
				type: "POST",
				url: "../../projeto/salvaravaliacao",
				data: $(this).serialize(),
				success: function(data) {
					if (data.trim().length > 0) {
						swal({
							title: "Atenção!",
							text: data,
							type: "error"
						});
					} else {
						carregarTela('<?= $this->escape($urlRetornoProjeto) ?>');
					}

					$('.salvar-avaliacao-projeto').prop('disabled', false);
				},
				error: function() {
					$('.salvar-avaliacao-projeto').prop('disabled', false);

					swal({
						title: "Atenção!",
                        text: "Não foi possível salvar os pareceres do projeto.",
						type: "error"
					});
				}
			});
		});
	});
</script>
<? endif; ?>
