<script type="text/javascript">
	$(document).ready(function() {
		$('#form-aceite-termo-projetos').on('submit', function(e) {
			e.preventDefault();

			if (!$('#aceite_termo').is(':checked')) {
				swal({
					title: "Atenção!",
					text: "Confirme o aceite do termo para continuar.",
					type: "warning"
				});
				return false;
			}

			$('#btn-aceitar-termo-projetos').prop('disabled', true);

			$.ajax({
				type: "POST",
				url: "../../inscricao/salvaraceitetermo",
				data: $(this).serialize(),
				success: function(data) {
					if (data.trim().length > 0) {
						$('#btn-aceitar-termo-projetos').prop('disabled', false);
						swal({
							title: "Atenção!",
							text: data,
							type: "error"
						});
						return;
					}

					swal({
						title: "Sucesso!",
						text: "Termo aceito com sucesso.",
						type: "success",
						timer: 1,
						showConfirmButton: false
					}, function() {
						swal.close();
						carregarTela('../../projeto?id_inscricao=<?= (int) $this->id_inscricao ?>');
					});
				},
				error: function() {
					$('#btn-aceitar-termo-projetos').prop('disabled', false);
					swal({
						title: "Atenção!",
						text: "Não foi possível registrar o aceite do termo.",
						type: "error"
					});
				}
			});
		});

		<? if (empty($this->aceiteTermoPendente)) : ?>
		$(document).on('click', '.js-download-selo', function(e) {
			var botao = $(this);
			if (botao.hasClass('is-loading')) {
				e.preventDefault();
				return false;
			}

			botao.addClass('is-loading');
			botao.attr('aria-disabled', 'true');
			botao.text('BAIXANDO...');

			window.setTimeout(function() {
				botao.removeClass('is-loading');
				botao.removeAttr('aria-disabled');
				botao.text('BAIXAR O SELO');
			}, 4000);
		});

		$(document).on('click', '.js-download-certificado', function(e) {
			e.preventDefault();

			var botao = $(this);
			if (botao.hasClass('is-loading')) {
				return false;
			}

			var nomeCertificado = <?= json_encode($nomeCertificado) ?>;
			var dataCertificado = <?= json_encode($dataCertificado) ?>;
			var nivelCertificado = <?= json_encode($nivelCertificado) ?>;
			var anoCertificado = <?= json_encode($anoCertificado) ?>;
			var urlSeloCertificado = <?= json_encode($urlSeloCertificado) ?>;
			var urlLogoInstituto = <?= json_encode($urlLogoInstituto) ?>;
			var urlLogoAcim = <?= json_encode($urlLogoAcim) ?>;
			var urlsOdsCertificado = <?= json_encode($urlsOdsCertificado) ?>;

			if (!nomeCertificado.length) {
				swal({
					title: "Atencao!",
					text: "Nao foi possivel identificar o nome para emitir o certificado.",
					type: "error"
				});
				return false;
			}

			botao.addClass('is-loading');
			botao.attr('aria-disabled', 'true');
			botao.text('PREPARANDO...');

			var janelaPreview = window.open('', '_blank');
			if (!janelaPreview) {
				botao.removeClass('is-loading');
				botao.removeAttr('aria-disabled');
				botao.text('VISUALIZAR CERTIFICADO');
				swal({
					title: "Atencao!",
					text: "Nao foi possivel abrir a visualizacao. Verifique se o navegador bloqueou a nova aba.",
					type: "error"
				});
				return false;
			}

			janelaPreview.document.write('<!DOCTYPE html><title>Gerando certificado...</title><body style="font-family: Arial, sans-serif; display:flex; align-items:center; justify-content:center; min-height:100vh; margin:0; color:#0f5553;">Gerando visualizacao do certificado...</body>');
			janelaPreview.document.close();

			var carregarImagemComoDataUrl = function(url) {
				return new Promise(function(resolve) {
					var imagem = new Image();
					imagem.crossOrigin = 'anonymous';
					imagem.onload = function() {
						var canvas = document.createElement('canvas');
						canvas.width = imagem.naturalWidth || imagem.width;
						canvas.height = imagem.naturalHeight || imagem.height;
						var contexto = canvas.getContext('2d');
						contexto.drawImage(imagem, 0, 0);
						resolve(canvas.toDataURL('image/png'));
					};
					imagem.onerror = function() {
						resolve(null);
					};
					imagem.src = url;
				});
			};

			var quebrarTexto = function(texto, tamanhoMaximo, maxLinhas) {
				var palavras = (texto || '').split(/\s+/);
				var linhas = [];
				var linhaAtual = '';

				$.each(palavras, function(_, palavra) {
					var candidata = linhaAtual ? (linhaAtual + ' ' + palavra) : palavra;
					if (candidata.length <= tamanhoMaximo || !linhaAtual) {
						linhaAtual = candidata;
						return;
					}

					linhas.push(linhaAtual);
					linhaAtual = palavra;
				});

				if (linhaAtual) {
					linhas.push(linhaAtual);
				}

				if (maxLinhas && linhas.length > maxLinhas) {
					var excedentes = linhas.slice(maxLinhas - 1).join(' ');
					linhas = linhas.slice(0, maxLinhas - 1);
					linhas.push(excedentes);
				}

				return linhas.join('\n');
			};

			Promise.all([
				carregarImagemComoDataUrl(urlSeloCertificado),
				carregarImagemComoDataUrl(urlLogoInstituto),
				carregarImagemComoDataUrl(urlLogoAcim),
				Promise.all($.map(urlsOdsCertificado, function(url) {
					return carregarImagemComoDataUrl(url);
				}))
			]).then(function(imagens) {
				var seloCertificado = imagens[0];
				var logoInstituto = imagens[1];
				var logoAcim = imagens[2];
				var imagensOds = imagens[3] || [];
				var nomeCertificadoFormatado = quebrarTexto(nomeCertificado.toUpperCase(), 20, 2);
				var descricaoCertificado = 'e uma organizacao comprometida com os principios Ambientais,\nSociais e de Governanca (ESG) e com os Objetivos de Desenvolvimento\nSustentavel (ODS), sendo reconhecida pelo Instituto ACIM em ' + anoCertificado + '.';
				var gradeOds = [];
				var primeiraLinhaOds = [];
				var segundaLinhaOds = [];

				$.each(imagensOds, function(indice, imagemOds) {
					if (!imagemOds) {
						return;
					}

					var itemOds = {
						image: imagemOds,
						width: 58,
						height: 58,
						margin: [0, 0, 4, 0]
					};

					if (indice < 9) {
						primeiraLinhaOds.push(itemOds);
						return;
					}

					segundaLinhaOds.push(itemOds);
				});

				if (primeiraLinhaOds.length) {
					gradeOds.push({
						columns: primeiraLinhaOds,
