					background: function() {
						var marcaDagua = seloCertificado ? [{ image: seloCertificado, width: 395, opacity: 0.08, absolutePosition: { x: 82, y: 64 } }] : [];
						return marcaDagua.concat([
							{ canvas: [{ type: 'line', x1: 62, y1: 28, x2: 62, y2: 240, lineWidth: 14, lineColor: '#0d5b58' }] },
							{ canvas: [{ type: 'line', x1: 62, y1: 28, x2: 265, y2: 28, lineWidth: 14, lineColor: '#0d5b58' }] },
							{ canvas: [{ type: 'line', x1: 83, y1: 240, x2: 83, y2: 546, lineWidth: 2.2, lineColor: '#0d5b58' }] },
							{ canvas: [{ type: 'line', x1: 83, y1: 546, x2: 755, y2: 546, lineWidth: 2.2, lineColor: '#0d5b58' }] },
							{ canvas: [{ type: 'line', x1: 755, y1: 546, x2: 755, y2: 178, lineWidth: 2.2, lineColor: '#0d5b58' }] },
							{ canvas: [{ type: 'line', x1: 240, y1: 36, x2: 630, y2: 36, lineWidth: 2.2, lineColor: '#0d5b58' }] }
