				<? if ($this->permissao == 1) : ?>
					<tr>
						<th></th>
						<th class="pr-1"><input type="text" class="form-control" placeholder="Pesquisar" /></th>
						<th class="pr-1"><input type="text" class="form-control" placeholder="Pesquisar" /></th>
