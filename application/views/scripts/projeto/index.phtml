				pdfMake.createPdf(docDefinition).getBlob(function(blob) {
					var urlPreview = URL.createObjectURL(blob);
					janelaPreview.location.href = urlPreview;
					janelaPreview.document.title = 'Certificado ' + nomeCertificado;

					window.setTimeout(function() {
						URL.revokeObjectURL(urlPreview);
					}, 60000);

					botao.removeClass('is-loading');
					botao.removeAttr('aria-disabled');
					botao.text('VISUALIZAR CERTIFICADO');
				});
			}).catch(function() {
				janelaPreview.close();
				botao.removeClass('is-loading');
				botao.removeAttr('aria-disabled');
				botao.text('VISUALIZAR CERTIFICADO');
