			</thead>
			<tbody>
				<?
				if (count($this->registros) > 0): foreach ($this->registros as $value):
					$odsNumero = 0;
					if (!empty($value['ods_principal']) && preg_match('/^ODS\s+([1-9]|1[0-7])$/', trim((string) $value['ods_principal']), $matches)) {
						$odsNumero = (int) $matches[1];
					}
				?>
						<tr>
							<td class="text-center projeto-table__actions" width="60px" data-label="Ações">
								<div class="table-actions">
									<a class="btn btn-primary" href="#" onclick="carregarTela('../../projeto/detalhes?id_projeto=<?= $value['id_projeto'] ?>')"><i class="fa fa-eye"></i></a>
									<? if (!empty($this->permitirEditarExcluir)) : ?>
										<a class="btn btn-primary" href="#" onclick="carregarTela('../../projeto/cadastro?id_projeto=<?= $value['id_projeto'] ?>')"><i class="fa fa-pencil-square-o"></i></a>
										<a class="btn btn-danger" href="#" onclick="remover('projeto',<?= $value['id_projeto'] ?>,'<?= $this->escape($value['nome']) ?>')"><i class="fa fa-trash-o"></i></a>
									<? endif; ?>
								</div>
							</td>
							<td class="text-left align-middle" data-label="Nome do projeto"><?= $this->escape($value['nome']) ?></td>
							<? if ($this->permissao == 1) : ?>
								<td class="text-left align-middle" data-label="Empresa"><?= !empty($value['nome_organizacao']) ? $this->escape($value['nome_organizacao']) : '-' ?></td>
							<? endif; ?>
							<td class="text-left align-middle" data-label="Área de atuação"><?= !empty($value['area_atuacao']) ? $this->escape($value['area_atuacao']) : '-' ?></td>
							<td class="text-left align-middle" data-label="Responsável"><?= !empty($value['responsavel']) ? $this->escape($value['responsavel']) : '-' ?></td>
							<td class="text-center align-middle projeto-table__ods" data-label="ODS principal">
								<? if ($odsNumero > 0): ?>
									<img src="../../objetivos/<?= $odsNumero ?>.png" alt="<?= $this->escape($value['ods_principal']) ?>" title="<?= $this->escape($value['ods_principal']) ?>" class="projeto-table__ods-image">
								<? else: ?>
									-
								<? endif; ?>
							</td>
							<td class="text-left align-middle" data-label="Status"><?= $this->escape($value['status_projeto_label']) ?></td>
						</tr>
				<? endforeach;
				endif; ?>
			</tbody>
		</table>
	</div>
</div>

<script type="text/javascript">
	$(document).ready(function() {
		var tableProjetos = $('#table_projetos').DataTable({
			orderCellsTop: true,
			language: {
				url: 'https://cdn.datatables.net/plug-ins/1.10.19/i18n/Portuguese-Brasil.json'
			},
			paging: <?= $this->permissao == 1 ? 'true' : 'false' ?>,
			info: <?= $this->permissao == 1 ? 'true' : 'false' ?>,
			"columnDefs": [{
				orderable: false,
				targets: [0]
			}],
			"order": [
				[1, 'asc']
			]
		});

		<? if ($this->permissao == 1) : ?>
			$('#table_projetos thead tr:eq(1) th').each(function(i) {
				$('input', this).on('keyup change', function() {
					if (tableProjetos.column(i).search() !== this.value) {
						tableProjetos.column(i).search(this.value).draw();
					}
				});
			});
		<? endif; ?>

		$('#submeter-projetos').on('click', function() {
			swal({
				title: "Confirmar submissão?",
				text: "Todos os projetos listados em rascunho serão enviados para o status Submetido.",
				type: "warning",
				showCancelButton: true,
				confirmButtonText: "Sim, submeter",
				cancelButtonText: "Cancelar"
			}, function(confirmado) {
				if (!confirmado) return;

				$.ajax({
					type: "POST",
					url: "../../projeto/submeterlistados",
					success: function(data) {
						if (data.trim().length > 0) {
							swal({
								title: "Atenção!",
								text: data,
								type: "error"
							});
							return;
						}

						swal({
							title: "Sucesso!",
							text: "Projetos submetidos com sucesso.",
							type: "success"
						}, function() {
							carregarTela('../../projeto');
						});
					},
					error: function() {
						swal({
							title: "Atenção!",
							text: "Não foi possível submeter os projetos.",
							type: "error"
						});
					}
				});
			});
		});
	});
</script>
