										{ text: nomeCertificadoFormatado, fontSize: 40, bold: true, color: '#0d5b58', lineHeight: 0.92, margin: [0, 0, 0, 18] },
										{ text: descricaoCertificado, fontSize: 17, color: '#202124', lineHeight: 1.22, margin: [0, 0, 0, 10] },
										{
											stack: gradeOds,
											margin: [0, 6, 0, 18]
										}
									]
								},
								{
									width: 150,
									stack: seloCertificado ? [
										{ image: seloCertificado, width: 132, alignment: 'right', margin: [0, 0, 0, 0] }
									] : []
								}
							]
						},
						{
							columns: [
								{
									width: '*',
									stack: [
										{
											canvas: [
												{ type: 'line', x1: 0, y1: 0, x2: 150, y2: 0, lineWidth: 1.2, lineColor: '#4b5563' }
											],
											margin: [0, 6, 0, 6]
										},
										{ text: 'Nadia Felippe Corazza', fontSize: 12.5, bold: true, color: '#202124', margin: [0, 0, 0, 2] },
										{ text: 'Presidente', fontSize: 11, color: '#202124' }
									]
								},
								{
									width: 125,
									stack: [
										{ text: 'Realizacao:', fontSize: 11.5, bold: true, color: '#374151', margin: [0, 0, 0, 6] },
										logoInstituto ? { image: logoInstituto, width: 86 } : { text: 'Instituto ACIM', fontSize: 12, bold: true, color: '#1f2937' }
									]
								},
								{
									width: 205,
									stack: [
										{ text: 'Parceiros:', fontSize: 11.5, bold: true, color: '#374151', margin: [0, 0, 0, 6] },
										logoAcim ? { image: logoAcim, width: 170, margin: [0, 0, 0, 8] } : { text: 'ACIM', fontSize: 14, bold: true, color: '#1f2937', margin: [0, 0, 0, 8] },
										{ text: 'SEBRAE', fontSize: 18, bold: true, color: '#0c67b2', margin: [0, 0, 0, 4] },
										{ text: 'Instituto Brasileiro de ESG', fontSize: 10.5, color: '#4b5563', margin: [0, 0, 0, 2] },
										{ text: 'Movimento Inovacao e ESG de Maringa', fontSize: 9.5, color: '#4b5563' }
									]
								}
							],
							margin: [0, 0, 0, 0]
						}
