<script type="text/javascript">
	$(document).ready(function() {
		var tableProjetos = $('#table_projetos').DataTable({
			orderCellsTop: true,
			language: {
				url: 'https://cdn.datatables.net/plug-ins/1.10.19/i18n/Portuguese-Brasil.json'
			},
			paging: <?= $this->permissao == 1 ? 'true' : 'false' ?>,
			info: <?= $this->permissao == 1 ? 'true' : 'false' ?>,
			"columnDefs": [{
				orderable: false,
				targets: [0]
			}],
			"order": [
				[1, 'asc']
			]
		});

		<? if ($this->permissao == 1) : ?>
			$('#table_projetos thead tr:eq(1) th').each(function(i) {
				$('input', this).on('keyup change', function() {
					if (tableProjetos.column(i).search() !== this.value) {
						tableProjetos.column(i).search(this.value).draw();
					}
				});
			});
		<? endif; ?>

		$('#submeter-projetos').on('click', function() {
			var subtituloSubmissao = "Todos os projetos listados em rascunho serao enviados para o status Submetido.";
			var termoCompromisso = <?= json_encode((string) ($this->configHelp['help_termo_submissao'] ?? '')) ?>;
			var linhasTermo = (termoCompromisso || '').split(/\r\n|\r|\n/);
			var linhasTermoHtml = [];

			$.each(linhasTermo, function(indice, linha) {
				var linhaEscapada = $('<div/>').text(linha).html();
				if (indice === 0 && linhaEscapada !== '') {
					linhasTermoHtml.push('<strong>' + linhaEscapada + '</strong>');
					return;
				}

				linhasTermoHtml.push(linhaEscapada);
			});

			var termoCompromissoHtml = '<div style="max-height: 220px; overflow-y: auto; text-align: left; padding: 14px 16px; margin-top: 4px; border: 1px solid #cbd5e1; border-radius: 10px; background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%); color: #1f2937; white-space: pre-line; font-size: 14px; line-height: 1.65; box-shadow: inset 0 1px 0 rgba(255,255,255,0.85), 0 8px 18px rgba(15, 23, 42, 0.08);">' +
				linhasTermoHtml.join('<br>') +
				'</div>';

			swal({
				title: "Confirmar submissão?",
				text: subtituloSubmissao + termoCompromissoHtml,
				html: true,
				type: "warning",
				showCancelButton: true,
				confirmButtonText: "Sim, submeter",
				cancelButtonText: "Cancelar"
			}, function(confirmado) {
				if (!confirmado) return;

				$.ajax({
					type: "POST",
					url: "../../projeto/submeterlistados",
					success: function(data) {
						if (data.trim().length > 0) {
							swal({
								title: "Atenção!",
								text: data,
								type: "error"
							});
							return;
						}

						swal({
							title: "Sucesso!",
							text: "Projetos submetidos com sucesso.",
							type: "success"
						}, function() {
							swal.close();
							carregarTela('../../projeto');
						});
					},
					error: function() {
						swal({
							title: "Atenção!",
							text: "Não foi possível submeter os projetos.",
							type: "error"
						});
					}
				});
			});
		});

		$('#avancar-status-auditoria').on('click', function() {
			var botao = $(this);
			var idInscricao = botao.data('id-inscricao');
			var statusAtualNome = botao.data('status-atual-nome') || ('#' + botao.data('status-atual'));
			var proximoStatusNome = botao.data('proximo-status-nome') || ('#' + botao.data('proximo-status'));

			swal({
				title: "Prosseguir projetos?",
				text: "Você avançará de " + statusAtualNome + " para " + proximoStatusNome + ".",
				type: "warning",
				showCancelButton: true,
				confirmButtonText: "Sim, avançar",
				cancelButtonText: "Cancelar"
			}, function(confirmado) {
				if (!confirmado) return;

				botao.prop('disabled', true);

				$.ajax({
					type: "POST",
					url: "../../inscricao/avancarstatusauditoria",
					data: {
						id_inscricao: idInscricao
					},
					success: function(data) {
						if (data.trim().length > 0) {
							botao.prop('disabled', false);
							swal({
								title: "Atencao!",
								text: data,
								type: "error"
							});
							return;
						}

						swal({
							title: "Sucesso!",
							text: "Inscricao encaminhada para o proximo status de auditoria.",
							type: "success"
						});

						setTimeout(function() {
							carregarTela('../../projeto?id_inscricao=<?= (int) $this->id_inscricao ?>');
						}, 500);
					},
					error: function() {
						botao.prop('disabled', false);
						swal({
							title: "Atencao!",
							text: "Nao foi possivel prosseguir a inscricao.",
							type: "error"
						});
					}
				});
			});
		});
	});
</script>
