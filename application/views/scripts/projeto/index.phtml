			info: <?= $this->permissao == 1 ? 'true' : 'false' ?>,
			"columnDefs": [{
				orderable: false,
				targets: [0]
			}],
			"order": [
				[1, 'asc']
			]
		});

		<? if ($this->permissao == 1) : ?>
			$('#table_projetos thead tr:eq(1) th').each(function(i) {
				$('input', this).on('keyup change', function() {
					if (tableProjetos.column(i).search() !== this.value) {
						tableProjetos.column(i).search(this.value).draw();
					}
				});
