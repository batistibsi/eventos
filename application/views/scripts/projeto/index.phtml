						<th class="text-left">EMPRESA</th>
					<? endif; ?>
					<th class="text-left">AREA DE ATUACAO</th>
					<th class="text-left">RESPONSAVEL</th>
					<th class="text-center">ODS PRINCIPAL</th>
					<th class="text-left">STATUS</th>
